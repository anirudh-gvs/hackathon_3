[flake8]
# =============================================================================
# Basic Configuration
# =============================================================================
# Maximum line length (matches Black and Pylint config)
max-line-length = 100

# Maximum McCabe complexity threshold
max-complexity = 10

# =============================================================================
# File and Directory Exclusions
# =============================================================================
# Exclude directories
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    .eggs,
    *.egg-info,
    node_modules,
    .mypy_cache,
    .ruff_cache,
    .pytest_cache,
    htmlcov,
    docs/_build,
    .eggs

# Exclude specific files
filename = 
    *.py

# =============================================================================
# Import Handling
# =============================================================================
# Import order style (matches isort/ruff)
import-order-style = google

# Application import names (for isort)
application-import-names = docscan,tests

# =============================================================================
# Extended Ignores (only when necessary)
# =============================================================================
# These are justified suppressions for this project

# E501: Line too long (handled by Black formatter)
extend-ignore = E501

# W503: Line break before binary operator (conflicts with Black)
extend-ignore = W503

# E203: Whitespace before ':' (conflicts with Black)
extend-ignore = E203

# E266: Too many leading '#' for block comment (allow for section headers)
extend-ignore = E266

# E501: Line too long (handled by Black)
extend-ignore = E501,W503,E203,E266

# =============================================================================
# Per-File Ignores
# =============================================================================
# Test files can have different standards
per-file-ignores =
    # Allow assert statements in tests
    tests/*:S101,
    # Allow print statements in tests
    tests/*:T201,
    # Allow missing docstrings in tests
    tests/*:D103,D104,D105,D107,
    # Allow long lines in test fixtures
    tests/fixtures/*:E501

# =============================================================================
# Docstring Configuration
# =============================================================================
# Docstring style (Google, NumPy, or PEP 257)
docstring-convention = google

# =============================================================================
# Statistics
# =============================================================================
# Count errors and warnings
statistics = True

# Show source code for each error
show-source = True

# Show pep8 text for each error
show-pep8 = False

# =============================================================================
# Formatting
# =============================================================================
# Format output as percentage
format = default

# =============================================================================
# Plugins (if installed)
# =============================================================================
# Enable flake8-docstrings
# enable-extensions = D

# Enable flake8-import-order
# enable-extensions = I

# Enable flake8-comprehensions
# enable-extensions = C

# Enable flake8-bugbear
# enable-extensions = B

# =============================================================================
# Bugbear Extensions (if installed)
# =============================================================================
# B001: Do not use bare except
# B002: Python 2 style super() call
# B003: Assigning to os.environ
# B004: Using hasattr(x, '__call__') to check if callable
# B005: Using .strip() with multi-character strings
# B006: Mutable default arguments
# B007: Loop control variable not used
# B008: Do not perform function calls in argument defaults
# B009: Do not call getattr with a constant attribute value
# B010: Do not call setattr with a constant attribute value
# B011: Do not return False inside boolean tests
# B012: Jupyter/ipython notebooks should have a shebang
# B013: Redundant exception handler
# B014: Exception handler handles same exception
# B015: Pointless comparison
# B016: Cannot raise literal
# B017: assertRaises(Exception)
# B018: Useless expression
# B019: Use of functools.lru_cache or functools.cache on method
# B020: Loop control variable not used
# B021: Pass multiple arguments to formatted string
# B022: No arguments passed to super()
# B023: Functions defined inside loops
# B024: Abstract base class has abstract methods
# B025: try-except with pass
# B026: Star-arg unpacking after keyword argument
# B027: Empty method in abstract base class
# B028: No explicit stacklevel keyword argument found
# B029: Non-default boolean in else clause
# B030: Class attributes should be defined in __init__ or with default values
# B031: Use of pickle
# B032: Try-except should not have a return statement
# B033: Duplicate set membership test
# B034: Pass or yield items by reference
# B035: Static except clause
# B036: Class-level attributes should be UpperCamelCase
# B037: Iteration over dict_keys should be replaced with set()
# B038: Use ternary operator for if-else
# B039: Use enumerate() instead of range(len())
# B040: Use isort to sort imports
# B041: Use future import annotations
# B042: Use from __future__ import annotations
# B043: Use defaultdict(dict) instead of setdefault
# B044: Use yaml.safe_load instead of yaml.load
# B045: Use decimal.Decimal for financial calculations
# B046: Use pathlib.Path instead of os.path
# B047: Use context manager for file operations
# B048: Use context manager for subprocess
# B049: Use pathlib.Path.mkdir with parents=True
# B050: Use tomllib instead of toml package
# B051: Use secrets module for security-sensitive operations
# B052: Use contextlib.suppress for ignored exceptions
# B053: Use contextlib.ExitStack for multiple context managers
# B054: Use subprocess.run instead of subprocess.call
# B055: Use subprocess.run instead of subprocess.check_output
# B056: Use subprocess.run instead of subprocess.Popen
# B057: Use subprocess.run instead of subprocess.Popen
# B058: Use subprocess.run instead of subprocess.Popen
# B059: Use subprocess.run instead of subprocess.Popen
# B060: Use f-strings instead of % formatting
# B061: Use f-strings instead of .format()
# B062: Use f-strings instead of string concatenation
# B063: Use f-strings instead of string.Template
# B064: Use f-strings instead of % formatting in logging
# B065: Use f-strings instead of % formatting in logging
# B066: Use f-strings instead of % formatting in logging
# B067: Use f-strings instead of % formatting in logging
# B068: Use f-strings instead of % formatting in logging
