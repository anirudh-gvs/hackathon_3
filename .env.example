# Offline DocScan - Environment Configuration
# Copy this file to .env and customize as needed
# DO NOT commit .env to version control

# =============================================================================
# Application Configuration
# =============================================================================

# Application environment (development, production, testing)
APP_ENV=development

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# Model Configuration
# =============================================================================

# Path to GGUF model file (default: models/phi3-mini-q4.gguf)
MODEL_PATH=models/phi3-mini-q4.gguf

# Model context window size (default: 4096)
MODEL_N_CTX=4096

# Number of threads for inference (default: 4)
MODEL_N_THREADS=4

# Number of GPU layers (0 for CPU-only, default: 0)
MODEL_N_GPU_LAYERS=0

# =============================================================================
# Inference Configuration
# =============================================================================

# Maximum tokens to generate (default: 1024)
INFERENCE_MAX_TOKENS=1024

# Temperature for inference (0.0-1.0, lower = more deterministic, default: 0.1)
INFERENCE_TEMPERATURE=0.1

# =============================================================================
# File Processing Configuration
# =============================================================================

# Default output directory for results
OUTPUT_DIR=output

# Temporary directory for processing
TEMP_DIR=tmp

# Maximum file size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# Supported file extensions (comma-separated)
SUPPORTED_EXTENSIONS=pdf,png,jpg,jpeg,bmp,txt,tiff

# =============================================================================
# OCR Configuration (Tesseract)
# =============================================================================

# Tesseract OCR language (default: eng)
# Install language packs: tesseract-ocr-[lang]
OCR_LANGUAGE=eng

# OCR mode (0-3, higher = more accurate but slower, default: 3)
OCR_MODE=3

# =============================================================================
# PDF Processing Configuration
# =============================================================================

# PDF extraction strategy (text, layout, or hybrid, default: text)
PDF_STRATEGY=text

# Maximum PDF pages to process (0 = unlimited, default: 0)
PDF_MAX_PAGES=0

# =============================================================================
# Output Configuration
# =============================================================================

# Default output format (json, csv, txt, default: json)
OUTPUT_FORMAT=json

# Pretty print JSON output (true/false, default: true)
JSON_PRETTY_PRINT=true

# Include metadata in output (true/false, default: true)
INCLUDE_METADATA=true

# =============================================================================
# Performance Configuration
# =============================================================================

# Enable parallel processing (true/false, default: false)
PARALLEL_PROCESSING=false

# Number of worker processes (default: 2)
WORKER_PROCESSES=2

# Cache extracted text (true/false, default: true)
ENABLE_CACHE=true

# Cache directory (default: .cache)
CACHE_DIR=.cache

# =============================================================================
# Security Configuration
# =============================================================================

# Allow processing of files outside current directory (true/false, default: false)
ALLOW_ABSOLUTE_PATHS=false

# Enable file type validation (true/false, default: true)
VALIDATE_FILE_TYPES=true

# Maximum recursion depth for nested documents (default: 10)
MAX_RECURSION_DEPTH=10

# =============================================================================
# Development & Debugging
# =============================================================================

# Enable verbose output (true/false, default: false)
VERBOSE=false

# Show extracted text before inference (true/false, default: false)
SHOW_EXTRACTED_TEXT=false

# Enable debug mode (true/false, default: false)
DEBUG=false

# Save intermediate results (true/false, default: false)
SAVE_INTERMEDIATE=false

# =============================================================================
# External Tools (Optional)
# =============================================================================

# Path to Tesseract executable (leave empty to use system PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Path to Poppler utils (for PDF processing, leave empty to use system PATH)
# POPPLER_PATH=C:\Program Files\poppler-utils

# =============================================================================
# Notes
# =============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Edit .env with your preferences
# 3. Never commit .env to version control
# 4. Most users can use the default values
# 5. Only MODEL_PATH is required if not using the default model location